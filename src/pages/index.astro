---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import PhilosophyPillars from '../components/sections/PhilosophyPillars.astro';
import CTABanner from '../components/sections/CTABanner.astro';
---

<PageLayout
  title="Luxury Med Spa in Tierra Verde, FL"
  description="Love Yourself Enough To Transform — A luxury physician-guided med spa devoted to holistic beauty, natural renewal, and total transformation."
>
  <Hero
    badge="Luxury Med Spa"
    headline="Love Yourself Enough to <em class='text-primary not-italic'>Transform</em>"
    subheadline="Sculpt. Restore. Elevate. Transform."
    body="Where medical precision meets luxury indulgence. Advanced, medically guided treatments designed to contour, rejuvenate, and awaken your confidence — so you don't just look refreshed, you look transformed."
    primaryCTA={{ text: "Book a Consultation", href: "#" }}
    secondaryCTA={{ text: "View Treatments", href: "/services" }}
    featuredCard={{ label: "Signature Experience", title: "Non-Invasive Body Contouring" }}
    socialProof="Personalized treatments guided by licensed medical professionals"
  />

  <PhilosophyPillars />

  <CTABanner
    headline="Ready to Begin Your Transformation?"
    body="Every detail is tailored — from our expert medical team and cutting-edge technology to our serene, coastal-luxury atmosphere."
    primaryCTA={{ text: "Book a Consultation", href: "#" }}
    secondaryCTA={{ text: "Explore Services", href: "/services" }}
    variant="dark"
  />
</PageLayout>
