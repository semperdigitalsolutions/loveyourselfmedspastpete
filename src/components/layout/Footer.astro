---
import { siteConfig } from '../../data/siteConfig';

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-background-dark">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <!-- Three-Column Grid: Contact | Location | Hours -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Contact Column -->
      <div class="text-center md:text-left">
        <h3
          class="text-primary font-display font-bold text-lg mb-6 tracking-wide"
        >
          Contact
        </h3>
        <ul class="space-y-4">
          <li class="flex items-center justify-center md:justify-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg"
              >call</span
            >
            <a
              href={`tel:${siteConfig.phone.replace(/\D/g, '')}`}
              class="text-sm hover:text-primary transition-colors"
              style="color: #F5E6E0;"
            >
              {siteConfig.phone}
            </a>
          </li>
          <li class="flex items-center justify-center md:justify-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg"
              >mail</span
            >
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-sm hover:text-primary transition-colors"
              style="color: #F5E6E0;"
            >
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Location Column -->
      <div
        class="text-center md:text-left md:border-x md:border-primary/30 md:px-8"
      >
        <h3
          class="text-primary font-display font-bold text-lg mb-6 tracking-wide"
        >
          Location
        </h3>
        <div class="flex items-start justify-center md:justify-start gap-3">
          <span class="material-symbols-outlined text-primary text-lg mt-0.5"
            >location_on</span
          >
          <address
            class="not-italic text-sm leading-relaxed"
            style="color: #F5E6E0;"
          >
            {siteConfig.address.street}<br />
            {
              siteConfig.address.suite && (
                <>
                  {siteConfig.address.suite}
                  <br />
                </>
              )
            }
            {siteConfig.address.city}, {siteConfig.address.state}
            {siteConfig.address.zip}
          </address>
        </div>
      </div>

      <!-- Hours Column -->
      <div class="text-center md:text-left">
        <h3
          class="text-primary font-display font-bold text-lg mb-6 tracking-wide"
        >
          Hours
        </h3>
        <ul class="space-y-3 text-sm" style="color: #F5E6E0;">
          <li class="flex items-center justify-center md:justify-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg"
              >schedule</span
            >
            <span>Mon &ndash; Fri: {siteConfig.hours.weekdays}</span>
          </li>
          <li class="flex items-center justify-center md:justify-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg"
              >calendar_today</span
            >
            <span>Saturday: {siteConfig.hours.saturday}</span>
          </li>
          <li class="flex items-center justify-center md:justify-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg"
              >event</span
            >
            <span>Sunday: {siteConfig.hours.sunday}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Rose Gold Divider -->
    <div
      class="mt-12 mb-8 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"
    >
    </div>

    <!-- Medical Disclaimer -->
    <div class="mb-8">
      <p
        class="text-xs leading-relaxed max-w-4xl mx-auto text-center"
        style="color: #F5E6E0; opacity: 0.5;"
      >
        Love Yourself Med Spa operates as a physician-guided medical spa. All
        medical aesthetic services are provided by or under the supervision of
        licensed medical professionals in accordance with state and federal
        regulations. Results may vary based on individual physiology, lifestyle,
        and adherence to treatment plans. No medical or aesthetic treatment is
        guaranteed. Consultations are required prior to all medical aesthetic
        procedures to determine candidacy, safety, and individualized treatment
        recommendations.
      </p>
    </div>

    <!-- Rose Gold Divider -->
    <div
      class="mb-6 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent"
    >
    </div>

    <!-- Bottom: Copyright + Tagline -->
    <div class="flex flex-col items-center gap-2 text-center">
      <p class="font-display italic text-primary text-sm tracking-wide">
        Love Yourself Enough to Transform
      </p>
      <p class="text-xs" style="color: #F5E6E0; opacity: 0.6;">
        &copy; {currentYear}
        {siteConfig.name}. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>
