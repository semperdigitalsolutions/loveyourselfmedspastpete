---
import { siteConfig, footerLinks } from '../../data/siteConfig';

const { address, phone, hours } = siteConfig;
const telHref = `tel:+1${phone.replace(/\D/g, '')}`;
const year = new Date().getFullYear();
---

<footer class="bg-background-dark text-white/80 px-6 py-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8 items-start">
      <div>
        <img
          src="/images/general/logo.png"
          alt="Love Yourself Med Spa logo"
          class="h-12 w-auto mb-4"
        />
        <p class="text-sm">
          Physician-guided aesthetic care in a luxurious, welcoming environment.
        </p>
      </div>
      <div class="text-sm space-y-2">
        <p class="flex items-start gap-2">
          <span
            class="material-symbols-outlined text-primary text-lg mt-0.5"
            aria-hidden="true">location_on</span
          >
          <address class="not-italic">
            {address.street}
            {address.suite}, {address.city}, {address.state}
            {address.zip}
          </address>
        </p>
        <p class="flex items-center gap-2">
          <span
            class="material-symbols-outlined text-primary text-lg"
            aria-hidden="true">call</span
          >
          <a href={telHref} class="hover:text-primary">{phone}</a>
        </p>
        <p class="flex items-start gap-2">
          <span
            class="material-symbols-outlined text-primary text-lg mt-0.5"
            aria-hidden="true">schedule</span
          >
          <span>
            Mon–Fri {hours.weekdays}<br />
            Sat {hours.saturday}<br />
            Sun {hours.sunday}
          </span>
        </p>
      </div>
      <div class="text-xs text-white/60 space-y-3">
        <p>
          New clients only. Consultation required. Cannot be combined with other
          offers. Some exclusions may apply.
        </p>
        <div class="flex gap-4">
          {
            footerLinks.legal.map((link) => (
              <a href={link.href} class="hover:text-primary">
                {link.label}
              </a>
            ))
          }
        </div>
        <p>© {year} Love Yourself Med Spa. All rights reserved.</p>
      </div>
    </div>

    <div
      class="mt-10 pt-6 border-t border-primary/20 text-xs text-white/50 leading-relaxed text-center max-w-4xl mx-auto"
    >
      <p>
        Love Yourself Med Spa operates as a physician-guided medical spa. All
        medical aesthetic services are provided by or under the supervision of
        licensed medical professionals in accordance with state and federal
        regulations. Results may vary based on individual physiology, lifestyle,
        and adherence to treatment plans. No medical or aesthetic treatment is
        guaranteed. Consultations are required prior to all medical aesthetic
        procedures to determine candidacy, safety, and individualized treatment
        recommendations.
      </p>
    </div>
  </div>
</footer>
