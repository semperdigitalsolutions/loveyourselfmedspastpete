---
import { siteConfig } from '../../data/siteConfig';

const fullAddress = `${siteConfig.address.street} ${siteConfig.address.suite}, ${siteConfig.address.city}, ${siteConfig.address.state} ${siteConfig.address.zip}`;
const encodedAddress = encodeURIComponent(fullAddress);
const mapsUrl = `https://www.google.com/maps?q=${encodedAddress}`;
const embedUrl = `https://www.google.com/maps?q=${encodedAddress}&output=embed`;
---

<section class="py-16 md:py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <span class="text-gold font-bold tracking-[0.2em] text-xs uppercase mb-4 block">
        Visit Us
      </span>
      <h2 class="text-3xl md:text-5xl font-display font-bold text-text-main mb-4">
        Find Your <span class="text-primary italic">Sanctuary</span>
      </h2>
      <p class="text-lg text-text-body max-w-2xl mx-auto">
        Nestled in the heart of Tierra Verde, our luxury spa awaits you.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-stretch">
      <!-- Map -->
      <div class="lg:col-span-3 rounded-2xl overflow-hidden shadow-lg min-h-[350px]">
        <iframe
          src={embedUrl}
          width="100%"
          height="100%"
          style="border:0; min-height:350px;"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          title="Love Yourself Med Spa location"
        ></iframe>
      </div>

      <!-- Info -->
      <div class="lg:col-span-2 bg-rose-soft/30 rounded-2xl p-8 flex flex-col justify-center">
        <div class="space-y-6">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">location_on</span>
            <div>
              <h3 class="font-display font-bold text-text-main mb-1">Address</h3>
              <p class="text-text-body text-sm leading-relaxed">
                {siteConfig.address.street}<br />
                {siteConfig.address.suite}<br />
                {siteConfig.address.city}, {siteConfig.address.state} {siteConfig.address.zip}
              </p>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">schedule</span>
            <div>
              <h3 class="font-display font-bold text-text-main mb-1">Hours</h3>
              <p class="text-text-body text-sm leading-relaxed">
                Mon–Fri: {siteConfig.hours.weekdays}<br />
                Saturday: {siteConfig.hours.saturday}<br />
                Sunday: {siteConfig.hours.sunday}
              </p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">call</span>
            <div>
              <h3 class="font-display font-bold text-text-main mb-1">Phone</h3>
              <a href={`tel:${siteConfig.phone.replace(/[^0-9+]/g, '')}`} class="text-text-body text-sm hover:text-primary transition-colors">
                {siteConfig.phone}
              </a>
            </div>
          </div>

          <!-- Get Directions -->
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-center block mt-4"
          >
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
