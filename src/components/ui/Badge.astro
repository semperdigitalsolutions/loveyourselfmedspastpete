---
interface Props {
  variant?: 'primary' | 'gold' | 'dark' | 'outline';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant = 'primary',
  size = 'sm',
  class: className
} = Astro.props;

const baseStyles = 'inline-flex items-center font-bold uppercase tracking-wider rounded-full';

const variants = {
  primary: 'bg-primary text-white',
  gold: 'bg-gold/10 text-gold',
  dark: 'bg-background-dark text-white',
  outline: 'border border-gray-200 text-text-body',
};

const sizes = {
  sm: 'px-3 py-1 text-[10px]',
  md: 'px-4 py-1.5 text-xs',
};

const classes = [baseStyles, variants[variant], sizes[size], className].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
