---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LoyaltyPopup from '../components/sections/LoyaltyPopup.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  hideNav?: boolean;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  hideNav = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  noindex={noindex}
>
  <Header hideNav={hideNav} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <LoyaltyPopup />
</BaseLayout>
