---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  showCTA?: boolean;
}

const { title, description, ogImage, showCTA: _showCTA = true } = Astro.props;
// Note: showCTA will be used when CTABanner component is implemented
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
