---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
// import LoyaltyPopup from '../components/sections/LoyaltyPopup.astro'; // TODO: Uncomment when memberships are live

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <!-- <LoyaltyPopup /> --> <!-- TODO: Uncomment when memberships are live -->
</BaseLayout>
